# VGold deploy credentials — copy this file to deploy.env (gitignored) and
# fill in the real values. deploy.env is read by deploy.sh; NEVER commit it.
DEPLOY_HOST=ftp.victorygenomics.com
DEPLOY_USER=vgold@victorygenomics.com
DEPLOY_PASS=CHANGE_ME

# Optional overrides (defaults shown):
# DEPLOY_PORT=21
# DEPLOY_REMOTE=/public_html
# DEPLOY_LOCAL=/path/to/vgold            # defaults to the repo directory
# DEPLOY_VERIFY_CERT=yes                 # set "no" ONLY if the FTP TLS cert cannot validate
