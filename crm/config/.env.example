# Victory Genomics CRM — Environment Configuration Example
# Copy this file to .env and fill in your credentials
# cp .env.example .env

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

APP_NAME=Victory Genomics CRM
APP_URL=https://crm.victorygenomics.com

# Twilio Configuration (can also be set in Admin > Settings)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# VoIP Settings
VOIP_ENABLED=1
VOIP_RECORDING_ENABLED=0

# WhatsApp Settings
WHATSAPP_ENABLED=1
WHATSAPP_SANDBOX_MODE=1
WHATSAPP_FROM_NUMBER=
